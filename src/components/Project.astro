---
import { ArrowUpRight } from "@lucide/astro";

interface Props {
  name: string;
  url: string;
  tagline: string;
  tech: string;
}
const { name, url, tagline, tech } = Astro.props;
---

<article>
  <a
    href={url}
    class="group inline-flex items-center gap-1 text-[0.95rem] font-medium hover:underline sm:text-base"
    target="_blank"
    rel="noreferrer"
  >
    {name}
    <ArrowUpRight size={14} stroke-width={1.75} class="opacity-60 group-hover:opacity-100" />
  </a>
  <p class="mt-1 text-[0.97rem] leading-6 text-neutral-700 sm:text-[1.02rem] dark:text-neutral-300">
    {tagline}
  </p>
  <p class="mt-0.5 text-xs leading-5 text-neutral-500 sm:text-sm">{tech}</p>
</article>
