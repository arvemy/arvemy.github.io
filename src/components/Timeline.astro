---
type Status = "ongoing" | "done";

interface Entry {
  date: string;
  title: string;
  sub?: string;
  status?: Status;
}
interface Props {
  entries: readonly Entry[];
}
const { entries } = Astro.props;
const [education, internship, graduation] = entries;
const timelineEntries = [
  education && graduation
    ? { ...education, date: `${education.date} - ${graduation.date}` }
    : education,
  internship,
].filter((entry): entry is Entry => Boolean(entry));

const dotClass = "bg-neutral-400 dark:bg-neutral-600";
---

<div class="relative mt-1.5">
  <ol class="space-y-2.5">
    {
      timelineEntries.map((e) => (
        <li class="relative pl-4">
          <span
            aria-hidden="true"
            class:list={["absolute left-0 top-1.5 size-1.5 rounded-full", dotClass]}
          />
          <p class="text-xs leading-5 text-neutral-500 sm:text-sm">{e.date}</p>
          <p class="mt-0.5 text-[0.95rem] leading-5 font-medium sm:text-[1rem]">{e.title}</p>
          {e.sub && <p class="mt-0.5 text-xs leading-5 text-neutral-500 sm:text-sm">{e.sub}</p>}
        </li>
      ))
    }
  </ol>
</div>
